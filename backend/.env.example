PORT=3000

# Database-login til SQL Server
DB_USER=DIT_BRUGERNAVN
DB_PASSWORD=DIT_PASSWORD
DB_SERVER=eksamensprojektprog2026.database.windows.net
DB_DATABASE=Ejendomsinvestering-app

# Datafordeler BBR REST
# Brug en tjenestebruger fra Datafordeler. Webbrugeren er typisk kun til administration.
# Gem aldrig BBR_USERNAME/BBR_PASSWORD i frontend.
BBR_USERNAME=DIT_DATAFORDELER_TJENESTEBRUGER_NAVN
BBR_PASSWORD=DIT_DATAFORDELER_TJENESTEBRUGER_PASSWORD
BBR_BASE_URL=https://services.datafordeler.dk/BBR/BBRPublic/1/rest
DAR_BFE_BASE_URL=https://services.datafordeler.dk/DAR/DAR_BFE_Public/1/REST

# Valgfri fallback til WFS/kortdata, hvis I senere bruger API-key.
BBR_API_KEY=DIN_DATAFORDELER_API_KEY
BBR_WFS_BASE_URL=https://wfs.datafordeler.dk/BBR/BBR_WFS/1.0.0/WFS

# Dataforsyningen kort-token
# Bruges til ortofoto/kortvisning via Dataforsyningens kortkomponent.
DATAFORSYNINGEN_MAP_TOKEN=DIN_DATAFORSYNINGEN_TOKEN
