PORT=3000

# Database-login til SQL Server
DB_USER=DIT_BRUGERNAVN
DB_PASSWORD=DIT_PASSWORD
DB_SERVER=eksamensprojektprog2026.database.windows.net
DB_DATABASE=Ejendomsinvestering-app

# Datafordeler BBR-login
# Bruges af backend til at hente BBR-data om en valideret adresse.
# Sæt jeres egne oplysninger i backend/.env, aldrig direkte i frontend.
BBR_USERNAME=DIT_DATAFORDELER_BRUGERNAVN
BBR_PASSWORD=DIT_DATAFORDELER_PASSWORD
BBR_BASE_URL=https://services.datafordeler.dk/BBR/BBRPublic/1/REST

# Datafordeler BBR API-key
# Bruges hvis vi henter BBR via WFS/API-key i stedet for REST-login.
BBR_API_KEY=DIN_DATAFORDELER_API_KEY
BBR_WFS_BASE_URL=https://wfs.datafordeler.dk/BBR/BBR_WFS/1.0.0/WFS

# Backend prøver først BBR REST-login og falder derefter tilbage til WFS/API-key,
# hvis Datafordeler afviser login-opslaget.
